# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
# Full signup instructions for each key are in SETUP.txt Step 2.

# ── Anthropic (Claude AI) ──────────────────────────────────────────────────
# Get your key at: console.anthropic.com → API Keys → Create Key
# Starts with: sk-ant-
ANTHROPIC_API_KEY=sk-ant-...

# ── Brave Search ───────────────────────────────────────────────────────────
# Get your key at: api.search.brave.com → API Keys → Create API Key (Free plan)
# Starts with: BSA
BRAVE_API_KEY=BSA...

# ── Tavily ─────────────────────────────────────────────────────────────────
# Get your key at: app.tavily.com (shown on dashboard after signup)
# Starts with: tvly-
TAVILY_API_KEY=tvly-...

# ── Adzuna ─────────────────────────────────────────────────────────────────
# Get both keys at: developer.adzuna.com → Dashboard → API Access Details
ADZUNA_APP_ID=your-app-id
ADZUNA_APP_KEY=your-app-key

# ── Gmail ──────────────────────────────────────────────────────────────────
# Use an App Password, NOT your regular Gmail login password.
# Create one at: myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on your Google account)
# The password looks like: xxxx xxxx xxxx xxxx — enter it without spaces.
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PW=xxxxxxxxxxxxxxxx

# ── USAJobs (optional) ─────────────────────────────────────────────────────
# Only needed for federal government job listings. Leave blank to skip.
# Register at: developer.usajobs.gov → Request an API Key
# Set USAJOBS_EMAIL to the email address you used to register.
USAJOBS_API_KEY=
USAJOBS_EMAIL=
